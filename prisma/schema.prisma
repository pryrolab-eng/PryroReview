generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  fullName      String
  email         String    @unique
  password      String
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  reviews       Review[]
  payments      Payment[]
  claims        Claim[]
  flags         Flag[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

model Company {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  category           String
  district           String
  website            String?
  phone              String?
  description        String?
  registrationNumber String?
  verified           Boolean   @default(false)
  verifiedSource     String?
  addedByUserId      String?
  createdAt          DateTime  @default(now())
  reviews            Review[]
  claims             Claim[]
}

model Review {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])
  rating    Int
  category  String
  comment   String
  response  String?
  createdAt DateTime @default(now())
  flags     Flag[]
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int      @default(20)
  method      String
  status      String   @default("pending")
  phoneNumber String
  referenceId String?
  companyId   String?
  createdAt   DateTime @default(now())
  review      Review?
}

model Claim {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  businessEmail String
  regNumber     String?
  status        ClaimStatus @default(PENDING)
  createdAt     DateTime    @default(now())
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model Flag {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SyncLog {
  id        String   @id @default(cuid())
  source    String
  imported  Int
  skipped   Int
  errors    Int
  createdAt DateTime @default(now())
}
